{
  "name": "@mr.dj2u/quantum-api",
  "version": "0.1.2",
  "description": "Package-ready TypeScript client for the Quantum API /v1 contract",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist-cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "dist-cjs",
    "README.md"
  ],
  "keywords": [
    "quantum",
    "api",
    "sdk",
    "typescript",
    "expo"
  ],
  "homepage": "https://github.com/davidjgrimsley/quantum-api",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidjgrimsley/quantum-api.git"
  },
  "bugs": {
    "url": "https://github.com/davidjgrimsley/quantum-api/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:cjs:meta",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:cjs:meta": "node ./scripts/write-cjs-package-json.cjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs tests/*.test.cjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
