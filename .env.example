APP_ENV=development
ROOT_PATH=
API_PREFIX=/v1
MAX_TEXT_LENGTH=2000
MAX_CIRCUIT_QUBITS=8
MAX_CIRCUIT_DEPTH=256
MAX_CIRCUIT_SHOTS=4096
ALLOW_ORIGINS=*
DEV_CORS_ALLOW_LOCALHOST=true
DEV_CORS_LOCAL_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://127.0.0.1:3000,http://localhost:19006,http://127.0.0.1:19006
REQUEST_TIMEOUT_SECONDS=5.0
REQUIRE_QISKIT=false
IBM_TOKEN=
IBM_INSTANCE=
IBM_CHANNEL=ibm_quantum_platform
IBM_CREDENTIAL_ENCRYPTION_KEY=
AUTH_ENABLED=true
API_KEY_HEADER=X-API-Key
API_KEY_HASH_SECRET=dev-only-change-me
API_KEY_FORMAT_PREFIX=qapi
API_KEY_PREFIX_LENGTH=12
API_KEY_SECRET_LENGTH=40
API_KEY_CACHE_TTL_SECONDS=90
DEFAULT_KEY_RATE_LIMIT_PER_SECOND=10
DEFAULT_KEY_RATE_LIMIT_PER_MINUTE=600
DEFAULT_KEY_DAILY_QUOTA=20000
MAX_ACTIVE_API_KEYS_PER_USER=5
MAX_TOTAL_API_KEYS_PER_USER=100
DATABASE_URL=sqlite+aiosqlite:///./quantum_api.db
DATABASE_AUTO_CREATE=true
SUPABASE_URL=https://example.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_CACHE_SECONDS=300
DEV_BOOTSTRAP_API_KEY_ENABLED=true
DEV_BOOTSTRAP_API_KEY=qapi_devlocal_0123456789abcdef0123456789abcdef
DEV_BOOTSTRAP_OWNER_ID=local-dev
RATE_LIMITING_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
DEV_RATE_LIMIT_BYPASS=true
PUBLIC_API_CORS_ALLOW_ALL=false
IP_RATE_LIMIT_PER_SECOND=20
IP_RATE_LIMIT_PER_MINUTE=900
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_TOKEN=
METRICS_TOKEN_HEADER=X-Metrics-Token
REQUEST_ID_HEADER=X-Request-ID
