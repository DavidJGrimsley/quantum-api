APP_ENV=development
API_PREFIX=/v1
MAX_TEXT_LENGTH=2000
MAX_CIRCUIT_QUBITS=8
MAX_CIRCUIT_DEPTH=256
MAX_CIRCUIT_SHOTS=4096
ALLOW_ORIGINS=*
REQUEST_TIMEOUT_SECONDS=5.0
REQUIRE_QISKIT=false
IBM_TOKEN=
IBM_INSTANCE=
IBM_CHANNEL=ibm_quantum
AUTH_ENABLED=true
API_KEY_HEADER=X-API-Key
API_KEYS_JSON=[{"key_id":"dev-local","key_hash_sha256":"3700285e3c8496a57e45eb1ccd43f2424852788576961320fbb31f86f17edb61","rate_limit_per_second":10,"rate_limit_per_minute":600,"daily_quota":20000,"enabled":true}]
RATE_LIMITING_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
DEV_RATE_LIMIT_BYPASS=true
IP_RATE_LIMIT_PER_SECOND=20
IP_RATE_LIMIT_PER_MINUTE=900
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_TOKEN=
METRICS_TOKEN_HEADER=X-Metrics-Token
REQUEST_ID_HEADER=X-Request-ID
